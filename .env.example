# IndiPaperTrade Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# ============================================
# REQUIRED: Angel One SmartAPI Credentials
# ============================================

# Your Angel One Client ID
SMARTAPI_CLIENT_ID=your_client_id_here

# Your SmartAPI API Key
SMARTAPI_API_KEY=your_api_key_here

# Your Angel One username
SMARTAPI_USERNAME=your_username_here

# Your Angel One password
SMARTAPI_PASSWORD=your_password_here

# Your SmartAPI Feed Token (for WebSocket)
SMARTAPI_FEED_TOKEN=your_feed_token_here

# ============================================
# OPTIONAL: Trading Configuration
# ============================================

# Initial capital for paper trading (in INR)
INITIAL_CAPITAL=500000

# Maximum leverage allowed (1.0 = no leverage)
MAX_LEVERAGE=2.0

# Enable slippage simulation
ENABLE_SLIPPAGE=False

# Slippage percentage (if enabled)
SLIPPAGE_PERCENT=0.01

# Enable bid-ask spread simulation
ENABLE_SPREAD=True

# Spread percentage
DEFAULT_SPREAD_PERCENT=0.02

# ============================================
# OPTIONAL: System Configuration
# ============================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/indipapertrade.log

# Database path
DATABASE_PATH=./data/indipapertrade.db

# ============================================
# OPTIONAL: Dashboard Configuration
# ============================================

# Dashboard host (default: 127.0.0.1)
DASHBOARD_HOST=127.0.0.1

# Dashboard port (default: 8501 for Streamlit)
DASHBOARD_PORT=8501

# Enable debug mode
DASHBOARD_DEBUG=False
